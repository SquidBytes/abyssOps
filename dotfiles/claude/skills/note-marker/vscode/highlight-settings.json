{
  "_comment": "Drop these keys into your VSCode user settings.json (Ctrl+Shift+P -> 'Preferences: Open User Settings (JSON)'). Requires the extension: fabiospampinato.vscode-highlight ('Highlight'). The filterFileRegex scopes every rule to note-marker notes dirs so ordinary markdown isn't colored.",

  "highlight.regexes": {
    "(\\*\\*STATUS\\*\\*(?:\\s*\\[#\\d+\\])?:\\s*DONE[^\\n]*)": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#4ade80", "fontWeight": "bold" }
      ]
    },
    "(\\*\\*STATUS\\*\\*(?:\\s*\\[#\\d+\\])?:\\s*TRACKED[^\\n]*)": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#60a5fa", "fontWeight": "bold" }
      ]
    },
    "(\\*\\*STATUS\\*\\*(?:\\s*\\[#\\d+\\])?:\\s*PARTIALLY TRACKED[^\\n]*)": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#fb923c", "fontWeight": "bold" }
      ]
    },
    "(\\*\\*STATUS\\*\\*(?:\\s*\\[#\\d+\\])?:\\s*NOT TRACKED[^\\n]*fits[^\\n]*)": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#facc15", "fontWeight": "bold" }
      ]
    },
    "(\\*\\*STATUS\\*\\*(?:\\s*\\[#\\d+\\])?:\\s*NOT TRACKED[^\\n]*Proposed[^\\n]*)": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#f87171", "fontWeight": "bold" }
      ]
    },
    "(\\*\\*STATUS\\*\\*(?:\\s*\\[#\\d+\\])?:\\s*NEEDS TRIAGE[^\\n]*)": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        {
          "color": "#ffffff",
          "backgroundColor": "#dc2626",
          "fontWeight": "bold",
          "border": "1px solid #7f1d1d",
          "borderRadius": "2px"
        }
      ]
    },
    "(\\*\\*STATUS\\*\\*(?:\\s*\\[#\\d+\\])?:\\s*DEFERRED[^\\n]*)": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#9ca3af", "fontStyle": "italic" }
      ]
    },
    "(\\[QUICK\\])": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        {
          "color": "#1f2937",
          "backgroundColor": "#bef264",
          "fontWeight": "bold",
          "borderRadius": "3px"
        }
      ]
    },
    "(\\[SUB-PHASE\\])": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        {
          "color": "#1f2937",
          "backgroundColor": "#fcd34d",
          "fontWeight": "bold",
          "borderRadius": "3px"
        }
      ]
    },
    "(\\[RESEARCH\\])": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        {
          "color": "#ffffff",
          "backgroundColor": "#e11d48",
          "fontWeight": "bold",
          "borderRadius": "3px"
        }
      ]
    },
    "(\\(NEW\\))": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#f472b6", "fontWeight": "bold" }
      ]
    },
    "(\\(planned\\))": {
      "filterFileRegex": ".*/notes/testing/.*\\.md$",
      "decorations": [
        { "color": "#a78bfa" }
      ]
    }
  }
}
